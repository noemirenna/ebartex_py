# Required: injected by start.sh (AWS SSM → docker-compose). No defaults in production.

# PostgreSQL (DATABASE_URL is built from these)
DB_USER=ebartex
DB_PASS=your-db-password
DB_HOST=ebartex-db-postgres.czuw0wy289sx.eu-south-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=ebartex_aste

# Secrets (must be set; app crashes at startup if missing)
MEILISEARCH_MASTER_KEY=your-meilisearch-master-key
SEARCH_ADMIN_API_KEY=your-search-admin-api-key
SECRET_KEY=your-app-secret-key
# FERNET_KEY optional; reserved for future token encryption. Omit or leave empty if unused.
# FERNET_KEY=your-fernet-key-base64
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Optional (defaults below)
DEBUG=false
# Explicit opt-in for /docs and /redoc. Do not rely on DEBUG in production.
ENABLE_OPENAPI_DOCS=false
# Set true only behind a trusted proxy that sets/validates X-Forwarded-For (rate limit uses real client IP).
TRUSTED_PROXY=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30

# Redis: app pool (reindex queue) uses REDIS_MAX_CONNECTIONS; SlowAPI rate limiter opens its own connections from REDIS_URL.
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_REINDEX_QUEUE=ebartex:reindex:queue
SEARCH_BASE_URL=http://localhost:8001
AUTH_BASE_URL=
AUTH_TIMEOUT_SECONDS=10
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_SEARCH=100
RATE_LIMIT_AUTH_LIKE=5
# Pagination: max offset (avoids O(offset) DB cost and DoS)
MAX_PAGINATION_OFFSET=10000
# Max bids returned in place_bid response (avoids unbounded list)
PLACE_BID_RESPONSE_BIDS_LIMIT=50
# JWT public key refresh (seconds; 0 = load once, no rotation without restart)
JWT_KEY_REFRESH_SECONDS=300
